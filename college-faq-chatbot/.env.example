# ============================================
# BVRIT Hyderabad College FAQ Chatbot
# Environment Configuration
# ============================================

# OpenRouter API Key (required)
# Get your API key from: https://openrouter.ai/keys
# IMPORTANT: Do NOT commit your real API key to source control. Replace the value below
# with your own key in a local `.env` file or set it as an environment variable.
OPENROUTER_API_KEY=sk-or-v1-your_api_key_here

# LLM Model (default: gpt-4o-mini)
# Supported: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
LLM_MODEL=gpt-4o-mini

# Embedding Model (default: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small

# OpenRouter Base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ChromaDB Persist Directory
CHROMA_DB_DIR=chroma_db

# Document Path
DOCUMENT_PATH=data/college_knowledge.docx

# Chunking Configuration
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retriever Configuration
TOP_K=5

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=false